# Environment Configuration for Development
NODE_ENV=development

# API Configuration
API_PORT=3000
API_HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/airline_booking_dev
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_REFRESH_EXPIRATION=7d

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# GDS API (Amadeus)
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local-key
AWS_SECRET_ACCESS_KEY=local-secret
AWS_S3_BUCKET=airline-booking-dev

# Sentry (Error Tracking)
SENTRY_DSN=

# Logging
LOG_LEVEL=debug

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_PAYMENT_KEY=your_razorpay_key
NEXT_PUBLIC_APP_NAME=Airline Booking System
NEXT_PUBLIC_ENVIRONMENT=development

# Security
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
FEATURE_LOUNGE_ACCESS=true
FEATURE_PREMIUM_BENEFITS=true
FEATURE_LOYALTY_PROGRAM=true
